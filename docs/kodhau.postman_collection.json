{
  "info": {
    "name": "KodHau API",
    "description": "KodHau платформасының REST API коллекциясы. Base URL: https://kodhau-backend.onrender.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://kodhau-backend.onrender.com",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string",
      "description": "Supabase JWT токені. /auth бетінен алып осы жерге қойыңыз."
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/health",
            "description": "Сервердің жұмыс істеп тұрғанын тексеру"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/courses",
            "description": "Барлық курстар тізімін алу"
          }
        },
        {
          "name": "Get Course by ID",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/courses/:id",
            "url_params": [
              { "key": "id", "value": "YOUR_COURSE_ID" }
            ],
            "description": "ID бойынша жеке курс алу"
          }
        },
        {
          "name": "Get Course Plan by Slug",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/courses/slug/python/plan",
            "description": "Slug бойынша толық курс жоспарын алу (модульдер → сабақтар → тапсырмалар)"
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/courses",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"JavaScript\",\n  \"slug\": \"javascript\",\n  \"description\": \"JS нөлден жоғары деңгейге\",\n  \"icon\": \"⚡\",\n  \"color\": \"#F59E0B\"\n}"
            },
            "description": "Жаңа курс жасау (admin/teacher)"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/courses/:id",
            "url_params": [
              { "key": "id", "value": "YOUR_COURSE_ID" }
            ],
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"JavaScript негіздері\",\n  \"slug\": \"javascript\",\n  \"description\": \"Жаңартылған сипаттама\",\n  \"icon\": \"⚡\",\n  \"color\": \"#F59E0B\"\n}"
            },
            "description": "Курсты жаңарту (admin/teacher)"
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/courses/:id",
            "url_params": [
              { "key": "id", "value": "YOUR_COURSE_ID" }
            ],
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "description": "Курсты жою (тек admin)"
          }
        }
      ]
    },
