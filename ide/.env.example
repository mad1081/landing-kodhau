# OpenRouter API key (required for AI mentor). Get one at https://openrouter.ai/keys
# Free models (e.g. :free suffix) have rate limits; paid credits unlock higher limits.
VITE_OPENROUTER_API_KEY=

# OpenRouter model ID (optional). Default: google/gemini-2.0-flash-exp:free
# See https://openrouter.ai/models for free and paid models.
# VITE_OPENROUTER_MODEL=

# ElevenLabs API key (required for voice; optional if Voice is OFF)
VITE_ELEVENLABS_API_KEY=

# ElevenLabs voice ID (optional; default is used if not set)
# VITE_ELEVENLABS_VOICE_ID=

# Supabase (add your project URL and anon key from supabase.com → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Landing page URL — used for redirect links
# Production:
VITE_LANDING_URL=https://kodhau-ai.vercel.app
# Local dev (uncomment and comment line above):
# VITE_LANDING_URL=http://localhost:3000
